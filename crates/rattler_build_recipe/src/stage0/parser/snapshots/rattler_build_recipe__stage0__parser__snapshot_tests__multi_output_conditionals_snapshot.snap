        else: nmake all
- package:
    name: conditional-pkg
    version: 3.0.0
  inherit: build-stage
  requirements:
    run:
    - if: linux
      then:
      - libgcc-ng
      - libstdcxx-ng
    - if: osx
      then: libcxx
    - if: win
      then: vs2019-runtime
