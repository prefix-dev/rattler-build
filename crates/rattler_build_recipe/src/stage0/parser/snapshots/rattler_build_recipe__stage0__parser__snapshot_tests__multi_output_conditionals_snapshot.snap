      ignore_binary_files: false
    post_process: []
  about:
    license: BSD-3-Clause
    summary: Package with platform-specific dependencies
  tests:
  - script:
      content:
      - if: unix
        then: test -f $PREFIX/bin/conditional-pkg
      - if: win
        then: if not exist %PREFIX%\\Library\\bin\\conditional-pkg.exe exit 1
